{
  "manifest_version": 3,
  "name": "Job Application Auto-Fill",
  "version": "0.1.0",
  "description": "Reads job application forms and fills them from your profile using Gemini.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "notifications"],
  "host_permissions": ["<all_urls>"],
  "icons": { "128": "icon.png" },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "action": {
    "default_title": "Open Job Application Auto-Fill",
    "default_icon": { "128": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extract.js", "content/fill.js", "content/submit-guard.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["prompts/field-map.md"], "matches": ["<all_urls>"] }
  ]
}
